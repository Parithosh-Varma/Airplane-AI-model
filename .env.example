# Database
DATABASE_URL=sqlite+pysqlite:///data/pipeline.db

# Scraper
USE_PLAYWRIGHT=false
POLITENESS_DELAY_MIN=30
POLITENESS_DELAY_MAX=120
MAX_RETRIES=5
BACKOFF_BASE=2
REQUEST_TIMEOUT=30

# Proxy (residential proxy rotation)
# Sign up at https://www.webshare.io/ or https://brightdata.com/ for residential proxies
PROXY_ROTATION_URL=
PROXY_API_KEY=

# Training
TRAIN_BATCH_SIZE=32
EPOCHS_PER_BATCH=5
LEARNING_RATE=0.0001
MIN_NEW_IMAGES=500
CHECK_INTERVAL_SECONDS=300
MODEL_NAME=resnet50
NUM_CLASSES=100
TORCH_DEVICE=cpu

# Logging
LOG_LEVEL=INFO
